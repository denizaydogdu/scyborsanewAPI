server:
  port: 8081

spring:
  application:
    name: scyborsaApi
  task:
    scheduling:
      pool:
        size: 3
  datasource:
    url: jdbc:postgresql://localhost:5432/scyborsa_db?currentSchema=public&ssl=false
    username: ${DB_USERNAME:admin}
    password: ${DB_PASSWORD:CHANGE_ME}
    driver-class-name: org.postgresql.Driver
    hikari:
      connection-timeout: 30000
      idle-timeout: 600000
      max-lifetime: 1800000
  jpa:
    database-platform: org.hibernate.dialect.PostgreSQLDialect
    hibernate:
      ddl-auto: update
    show-sql: true

kap:
  cache:
    ttl-minutes: 10
  news:
    api-url: https://news-mediator.tradingview.com/news-flow/v1/news
    market-news-url: https://news-headlines.tradingview.com/v2/headlines
    world-news-url: https://news-mediator.tradingview.com/news-flow/v1/news
    logo-base-url: https://s3-symbol-logo.tradingview.com/
    story-base-url: https://tr.tradingview.com
    connect-timeout-seconds: 10
    request-timeout-seconds: 15

velzon:
  api:
    base-url: ${VELZON_API_URL:https://api.velzon.tr}
    api-key: ${VELZON_API_KEY:CHANGE_ME}
    connect-timeout-seconds: 10
    request-timeout-seconds: 15
  ai:
    url: ${VELZON_AI_URL:https://api.velzon.tr/api/ai/raw-query}
    api-key: ${VELZON_AI_API_KEY:CHANGE_ME}
    enabled: ${VELZON_AI_ENABLED:false}
    timeout: 60
    max-tokens: 500
    temperature: 0.7
    rate-limit: 1000

cors:
  allowed-origins: http://localhost:8080
  max-age-seconds: 3600

tradingview:
  headers:
    origin: https://tr.tradingview.com
    referer: https://tr.tradingview.com/
  http:
    connect-timeout-seconds: 10
    request-timeout-seconds: 15
  chart:
    websocket-wait-ms: 200
  websocket:
    auth:
      token: ${TV_WS_AUTH_TOKEN:CHANGE_ME}
    cookie:
      value: ${TV_WS_COOKIE:CHANGE_ME}
  auth:
    token: ${TV_AUTH_TOKEN:CHANGE_ME}
  screener:
    url: https://scanner.tradingview.com/turkey/scan?label-product=screener-stock
  cookie:
    value: ${TV_COOKIE:CHANGE_ME}

screener:
  rate-limit-sleep-ms: 1500

sector:
  cache:
    ttl-seconds: 120

fund:
  cache:
    ttl-seconds: 120

analyst-rating:
  cache:
    ttl-seconds: 86400

fintables:
  api:
    base-url: https://api.fintables.com
    bearer-token: ${FINTABLES_BEARER_TOKEN:CHANGE_ME}
    akd-token: ${FINTABLES_AKD_TOKEN:CHANGE_ME}
    takas-token: ${FINTABLES_TAKAS_TOKEN:CHANGE_ME}
    brokerage-token: ${FINTABLES_BROKERAGE_TOKEN:CHANGE_ME}
    orderbook-token: ${FINTABLES_ORDERBOOK_TOKEN:CHANGE_ME}
    takas-list-token: ${FINTABLES_TAKAS_LIST_TOKEN:CHANGE_ME}
    cookie: ${FINTABLES_COOKIE:CHANGE_ME}
    connect-timeout-seconds: 10
    request-timeout-seconds: 15

telegram:
  enabled: ${TELEGRAM_ENABLED:false}
  bot:
    token: ${TELEGRAM_BOT_TOKEN:CHANGE_ME}
    chat-id: ${TELEGRAM_CHAT_ID:CHANGE_ME}
    topic-id: ${TELEGRAM_TOPIC_ID:0}
  ai:
    topic-id: ${TELEGRAM_AI_TOPIC_ID:8}
    enabled: ${TELEGRAM_AI_ENABLED:false}
    fallback-to-main: true
  screenshot:
    enabled: ${TELEGRAM_SCREENSHOT_ENABLED:false}
    api-key: ${CHARTIMG_API_KEY:CHANGE_ME}
    api-url: https://api.chart-img.com
    layout-id: ${CHARTIMG_LAYOUT_ID:CHANGE_ME}
    width: 1920
    height: 1080
    interval: 1D
    theme: dark
    timezone: Europe/Istanbul
    format: png
    timeout: 30
  kgs:
    filter-enabled: ${TELEGRAM_KGS_FILTER:false}
    min-score: ${TELEGRAM_KGS_MIN_SCORE:70}
  kap:
    topic-id: ${TELEGRAM_KAP_TOPIC_ID:0}
    max-per-cycle: ${TELEGRAM_KAP_MAX_PER_CYCLE:5}
  chart-base-url: "https://www.tradingview.com/chart/?symbol=BIST:"
  send-rate-limit-ms: 200

# Gate Velzon API (bilanco, rasyo, finansal rapor)
gate:
  velzon:
    base-url: ${GATE_VELZON_URL:https://gate.velzon.tr}
    api-key: ${GATE_VELZON_API_KEY:CHANGE_ME}
    connect-timeout-seconds: 10
    request-timeout-seconds: 30

# Django API (velzon-django formasyon tarama)
django:
  api:
    base-url: ${DJANGO_API_URL:http://209.38.247.159:8001}
    api-key: ${DJANGO_API_KEY:CHANGE_ME}
    connect-timeout-seconds: 10
    request-timeout-seconds: 30

haber:
  sync:
    enabled: true
    fixed-delay: 60000
    max-fetch-per-cycle: 5
    fetch-timeout: 10000
    max-stored: 100
    fetch-delay: 1000
